{
    "name": "@endpoints/express-server",
    "author": "Workleap",
    "version": "0.0.0",
    "description": "Express server to test Honeycomb distributed tracing.",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "//scripts-dev": "Adding the watch option to the dev script seems to not restart the server through refreshes.",
    "scripts": {
        "dev": "tsx src/index.ts",
        "serve-build": "tsx src/index.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo"
    },
    "dependencies": {
        "@opentelemetry/api": "1.9.1",
        "@opentelemetry/auto-instrumentations-node": "0.78.0",
        "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
        "@opentelemetry/instrumentation-express": "0.68.0",
        "@opentelemetry/instrumentation-http": "0.220.0",
        "@opentelemetry/sdk-node": "0.220.0",
        "cors": "2.8.6",
        "dotenv": "17.4.2",
        "express": "5.2.1"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/node": "26.1.1",
        "@typescript-eslint/parser": "8.63.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@workleap/eslint-configs": "2.0.4",
        "@workleap/typescript-configs": "5.0.0",
        "eslint": "9.39.2",
        "tsx": "4.23.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0"
    }
}
