{
    "name": "@squide/firefly-webpack-configs",
    "author": "Workleap",
    "version": "5.2.11",
    "description": "Webpack configuration helpers for the Squide firefly technology stack.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-squide.git",
        "directory": "packages/firefly-webpack-configs"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "dev": "rslib build --watch --config ./rslib.dev.ts",
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "@swc/core": "^1.15.40",
        "@swc/helpers": "^0.5.23",
        "@workleap/swc-configs": "^2.3.12",
        "browserslist": "^4.28.2",
        "postcss": "^8.5.3",
        "webpack": "^5.107.2",
        "webpack-dev-server": "^5.2.4"
    },
    "dependencies": {
        "@module-federation/enhanced": "2.5.0",
        "@workleap/webpack-configs": "^1.6.13",
        "deepmerge": "^4.3.1",
        "html-webpack-plugin": "^5.6.7",
        "semver": "^7.8.1"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "2.0.10",
        "@rslib/core": "0.22.0",
        "@types/node": "25.9.1",
        "@types/semver": "7.7.1",
        "@typescript-eslint/parser": "8.60.1",
        "@typescript/native-preview": "7.0.0-dev.20260602.1",
        "@workleap/eslint-configs": "2.0.3",
        "@workleap/rslib-configs": "1.2.0",
        "@workleap/typescript-configs": "4.0.2",
        "eslint": "9.39.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0",
        "vitest": "4.1.8",
        "webpack": "5.107.2",
        "webpack-dev-server": "5.2.4"
    },
    "sideEffects": false
}
