{
    "name": "@squide/firefly-storybook",
    "author": "Workleap",
    "version": "1.0.5",
    "description": "Squide firefly helpers for Storybook.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-squide.git",
        "directory": "packages/firefly-storybook"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            }
        }
    },
    "exports": "./src/index.ts",
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "@opentelemetry/api": "^1.9.1",
        "@storybook/react": "^10.3.3",
        "@tanstack/react-query": "^5.96.2",
        "launchdarkly-js-client-sdk": "^3.9.1",
        "msw": "^2.12.14",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "react-router": "^7.14.0",
        "storybook": "^10.3.5"
    },
    "peerDependenciesMeta": {
        "@opentelemetry/api": {
            "optional": true
        }
    },
    "dependencies": {
        "@squide/env-vars": "workspace:^",
        "@squide/firefly": "workspace:^",
        "@squide/launch-darkly": "workspace:^",
        "@squide/msw": "workspace:^",
        "@workleap-telemetry/core": "^2.0.1",
        "@workleap/logging": "^1.3.7"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rslib/core": "0.20.3",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.5.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260407.1",
        "@vitejs/plugin-react": "6.0.1",
        "@workleap/eslint-configs": "2.0.1",
        "@workleap/rslib-configs": "1.1.11",
        "@workleap/typescript-configs": "4.0.0",
        "eslint": "9.39.2",
        "happy-dom": "20.8.9",
        "typescript": "6.0.2",
        "typescript-eslint": "8.54.0",
        "vitest": "4.1.3"
    },
    "sideEffects": false
}
