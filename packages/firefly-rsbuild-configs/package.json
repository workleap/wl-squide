{
    "name": "@squide/firefly-rsbuild-configs",
    "author": "Workleap",
    "version": "2.2.9",
    "description": "Rsbuild configuration helpers for the Squide firefly technology stack.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-squide.git",
        "directory": "packages/firefly-rsbuild-configs"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "dev": "rslib build --watch --config ./rslib.dev.ts",
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "@rsbuild/core": "^2.1.5",
        "@rspack/core": "^2.1.3"
    },
    "dependencies": {
        "@module-federation/enhanced": "2.7.0",
        "@module-federation/rsbuild-plugin": "2.7.0",
        "@workleap/rsbuild-configs": "^4.1.1",
        "deepmerge": "^4.3.1",
        "semver": "^7.8.5"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "2.1.5",
        "@rslib/core": "0.23.2",
        "@rspack/core": "2.1.3",
        "@types/node": "26.1.1",
        "@types/semver": "7.7.1",
        "@typescript-eslint/parser": "8.63.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@workleap/eslint-configs": "2.0.4",
        "@workleap/rslib-configs": "1.2.1",
        "@workleap/typescript-configs": "5.0.0",
        "eslint": "9.39.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0",
        "vitest": "4.1.10"
    },
    "sideEffects": false
}
