{
    "name": "@squide/core",
    "author": "Workleap",
    "version": "7.1.1",
    "description": "The core package of @squide application shell.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-squide.git",
        "directory": "packages/core"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./internal": {
                "types": "./dist/internal.d.ts",
                "import": "./dist/internal.js",
                "default": "./dist/internal.js"
            }
        }
    },
    "exports": {
        ".": "./src/index.ts",
        "./internal": "./src/internal.ts"
    },
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "@workleap/logging": "^2.0.0",
        "eventemitter3": "^5.0.4",
        "memoize": "^11.0.0"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "2.1.6",
        "@rslib/core": "0.23.2",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@typescript-eslint/parser": "8.64.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@vitejs/plugin-react": "6.0.3",
        "@workleap/eslint-configs": "2.0.4",
        "@workleap/rslib-configs": "1.2.1",
        "@workleap/typescript-configs": "5.0.0",
        "eslint": "9.39.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0",
        "vitest": "4.1.10"
    },
    "sideEffects": false
}
