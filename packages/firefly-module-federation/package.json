{
    "name": "@squide/firefly-module-federation",
    "author": "Workleap",
    "version": "3.0.0",
    "description": "Add support for Module Federation to Squide firefly.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-squide.git",
        "directory": "packages/firefly-module-federation"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            }
        }
    },
    "exports": "./src/index.ts",
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "@opentelemetry/api": "^1.9.1",
        "@tanstack/react-query": "^5.101.2",
        "msw": "^2.15.0",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "react-router": "^8.2.0"
    },
    "dependencies": {
        "@module-federation/enhanced": "2.7.0",
        "@rspack/core": "^2.1.3",
        "@squide/core": "workspace:^",
        "@squide/firefly": "workspace:^",
        "@workleap/logging": "^2.0.0"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "2.1.5",
        "@rslib/core": "0.23.2",
        "@testing-library/react": "16.3.2",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.63.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@vitejs/plugin-react": "6.0.3",
        "@workleap/eslint-configs": "2.0.4",
        "@workleap/rslib-configs": "1.2.1",
        "@workleap/typescript-configs": "5.0.0",
        "eslint": "9.39.2",
        "happy-dom": "20.10.6",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0",
        "vitest": "4.1.10"
    },
    "sideEffects": false
}
