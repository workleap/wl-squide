{
    "name": "workspace-root",
    "author": "Workleap",
    "version": "0.0.0",
    "description": "A modular web application shell.",
    "private": true,
    "type": "module",
    "license": "Apache-2.0",
    "scripts": {
        "dev-basic": "turbo run dev --filter=./samples/basic/*",
        "dev-basic-webpack": "turbo run dev --filter=./samples/basic-webpack/*",
        "dev-endpoints": "turbo run dev --filter=./samples/endpoints/*",
        "dev-storybook": "turbo run dev --filter=@storybook/app",
        "dev-docs": "retype start",
        "build-pkg": "turbo run build --filter=./packages/*",
        "build-basic": "turbo run build --filter=./samples/basic/*",
        "build-basic-webpack": "turbo run build --filter=./samples/basic-webpack/*",
        "build-endpoints": "turbo run build --filter=./samples/endpoints/*",
        "build-storybook": "turbo run build --filter=@storybook/app",
        "serve-basic": "turbo run serve-build --filter=./samples/basic/*",
        "serve-basic-webpack": "turbo run serve-build --filter=./samples/basic-webpack/*",
        "serve-endpoints": "turbo run serve-build --filter=./samples/endpoints/*",
        "serve-storybook": "turbo run serve-build --filter=@storybook/app",
        "deploy-basic": "cross-env NETLIFY=true turbo run deploy --filter=./samples/basic/*",
        "deploy-endpoints": "cross-env NETLIFY=true turbo run deploy --filter=./samples/endpoints/*",
        "deploy-endpoints-isolated": "cross-env NETLIFY=true turbo run deploy-isolated --filter=./samples/endpoints/*",
        "lint": "turbo run lint --continue",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "syncpack": "syncpack lint",
        "test": "turbo run test --continue",
        "changeset": "changeset",
        "publish-pkg": "changeset publish",
        "publish-pr-pkg": "pkg-pr-new publish ./packages/* --packageManager=pnpm --pnpm",
        "clean": "pnpm -r --parallel --include-workspace-root exec pnpx rimraf dist .turbo .rslib .netlify node_modules/.cache",
        "reset": "pnpm clean && pnpm run --sequential \"/^reset:.*/\"",
        "reset:modules": "pnpm -r --parallel --include-workspace-root exec pnpx rimraf node_modules pnpm-lock.yaml",
        "reset:templates": "cd templates/getting-started && pnpm reset:modules",
        "list-outdated-deps": "pnpm outdated -r --format list !eslint !@eslint/js !typescript-eslint !useless-lib",
        "update-outdated-deps": "pnpm run --sequential \"/^update-outdated-deps:.*/\"",
        "update-outdated-deps:update-versions": "pnpm update -r --latest !eslint !@eslint/js !typescript-eslint !useless-lib",
        "update-outdated-deps:update-peers": "syncpack fix",
        "update-outdated-deps:fix-pkg-json": "eslint --fix --no-cache --no-ignore package.json **/package.json"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "@eslint/js": "9.39.2",
        "@types/node": "26.1.1",
        "@typescript-eslint/parser": "8.63.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@workleap/eslint-configs": "2.0.4",
        "@workleap/typescript-configs": "5.0.0",
        "agent-browser": "0.31.1",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "pkg-pr-new": "0.0.75",
        "retypeapp": "4.6.0",
        "syncpack": "15.3.2",
        "turbo": "2.10.4",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=11"
    },
    "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
