{
    "name": "@basic-webpack/remote-module",
    "author": "Workleap",
    "version": "0.0.0",
    "description": "Remote module to showcase Squide.",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "dev": "webpack serve --config webpack.dev.js",
        "dev-isolated": "cross-env ISOLATED=true pnpm dev",
        "build": "webpack --config webpack.build.js",
        "serve-build": "pnpm http-server dist -p 8087 -P http://localhost:8087? -c-1",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo"
    },
    "dependencies": {
        "@basic-webpack/shared": "workspace:*",
        "@basic-webpack/shell": "workspace:*",
        "@react-aria/toast": "3.1.1",
        "@react-stately/toast": "3.2.1",
        "@squide/fakes": "workspace:*",
        "@squide/firefly": "workspace:*",
        "@workleap/logging": "1.3.8",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-router": "8.0.1",
        "useless-lib": "^2.1.0"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@squide/firefly-webpack-configs": "workspace:*",
        "@swc/core": "1.15.43",
        "@swc/helpers": "0.5.23",
        "@types/node": "26.0.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.62.1",
        "@typescript/native-preview": "7.0.0-dev.20260630.1",
        "@workleap/browserslist-config": "2.1.8",
        "@workleap/eslint-configs": "2.0.3",
        "@workleap/swc-configs": "2.3.12",
        "@workleap/typescript-configs": "5.0.0",
        "browserslist": "4.28.4",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "http-server": "14.1.1",
        "typescript": "6.0.3",
        "typescript-eslint": "8.54.0",
        "webpack": "5.108.3",
        "webpack-cli": "7.1.0",
        "webpack-dev-server": "5.2.5"
    }
}
